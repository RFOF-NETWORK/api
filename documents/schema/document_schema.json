{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Document",
  "type": "object",
  "required": ["document_id", "document_type", "status", "created_at"],
  "properties": {
    "document_id": {
      "type": "string",
      "format": "uuid"
    },
    "document_type": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["ACTIVE", "ARCHIVED", "DELETED", "DRAFT"]
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "checksum": {
      "type": "string"
    },
    "metadata": {
      "$ref": "metadata_schema.json"
    },
    "relations": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uuid"
      }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "workflow_state": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
