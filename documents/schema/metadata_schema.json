{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DocumentMetadata",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "language": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "sensitivity": {
      "type": "string",
      "enum": ["PUBLIC", "INTERNAL", "CONFIDENTIAL", "SECRET"]
    },
    "custom": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
