{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DocumentWorkflow",
  "type": "object",
  "required": ["state"],
  "properties": {
    "state": {
      "type": "string",
      "enum": [
        "CREATED",
        "VALIDATION_PENDING",
        "VALIDATED",
        "APPROVAL_PENDING",
        "APPROVED",
        "REJECTED",
        "PUBLISHED",
        "ARCHIVED"
      ]
    },
    "transitions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "conditions": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
